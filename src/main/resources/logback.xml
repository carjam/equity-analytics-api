<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Human-readable pattern; use when MEIKEN_LOG_FORMAT=pattern (e.g. local dev) -->
    <appender name="STDOUT_PATTERN" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} [%X{correlationId}] - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- JSON: timestamp, level, logger, thread, message, MDC (correlationId, requestId, userId), stack traces -->
    <appender name="STDOUT_JSON" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <includeMdcKeyName>correlationId</includeMdcKeyName>
            <includeMdcKeyName>requestId</includeMdcKeyName>
            <includeMdcKeyName>userId</includeMdcKeyName>
            <throwableConverter class="net.logstash.logback.stacktrace.ShortenedThrowableConverter">
                <maxDepthPerThrowable>30</maxDepthPerThrowable>
            </throwableConverter>
        </encoder>
    </appender>

    <!-- Default: JSON. Set system property logback.configuration or MEIKEN_LOG_FORMAT=pattern for pattern. -->
    <root level="INFO">
        <appender-ref ref="STDOUT_JSON"/>
    </root>

    <logger name="com.meiken" level="DEBUG"/>
    <logger name="io.ktor" level="INFO"/>
    <logger name="io.netty" level="WARN"/>
</configuration>
