{
  "title": "Meiken API",
  "panels": [
    {
      "title": "Request rate",
      "targets": [{ "expr": "rate(api_requests_total[5m])", "legendFormat": "{{endpoint}}" }],
      "type": "graph"
    },
    {
      "title": "Latency p95",
      "targets": [{ "expr": "histogram_quantile(0.95, rate(api_request_duration_seconds_bucket[5m])) by (le, endpoint)", "legendFormat": "{{endpoint}}" }],
      "type": "graph"
    },
    {
      "title": "Error rate by endpoint",
      "targets": [{ "expr": "sum(rate(api_requests_total{status!=\"200\"}[5m])) by (endpoint, status)", "legendFormat": "{{endpoint}} {{status}}" }],
      "type": "graph"
    },
    {
      "title": "Circuit breaker state",
      "targets": [{ "expr": "circuit_breaker_state_gauge", "legendFormat": "alphaVantage" }],
      "type": "stat"
    },
    {
      "title": "Cache hit rate",
      "targets": [{ "expr": "cache_hit_rate", "legendFormat": "hit rate" }],
      "type": "gauge"
    },
    {
      "title": "Parallel fetch duration",
      "targets": [{ "expr": "rate(parallel_fetch_duration_seconds_sum[5m]) / rate(parallel_fetch_duration_seconds_count[5m])", "legendFormat": "avg" }],
      "type": "graph"
    }
  ],
  "schemaVersion": 38,
  "version": 1
}
